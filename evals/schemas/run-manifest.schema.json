{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "kb-agent.run-manifest.v1",
  "title": "KB-Agent eval run manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["run_id", "type", "versions", "inputs", "aggregate", "meta"],
  "properties": {
    "run_id": { "type": "string" },
    "type": { "type": "string", "enum": ["behavior", "state", "calibration"] },
    "created_at": { "type": "string" },
    "timestamp": { "type": "string" },
    "versions": {
      "type": "object",
      "required": ["agent_prompt", "dataset", "rubric"],
      "properties": {
        "agent_prompt": { "type": "string" },
        "dataset": { "type": "string" },
        "rubric": { "type": "string" }
      }
    },
    "inputs": {
      "type": "object",
      "required": ["case_count"],
      "properties": {
        "actor_output": { "type": "string" },
        "case_count": { "type": "integer", "minimum": 1 },
        "splits": { "type": "object" }
      }
    },
    "aggregate": {
      "type": "object",
      "required": ["composite", "dimensions", "weights"],
      "properties": {
        "composite": { "type": "number", "minimum": 0, "maximum": 10 },
        "dimensions": { "type": "object" },
        "weights": { "type": "object" }
      }
    },
    "meta": {
      "type": "object",
      "properties": {
        "split": { "type": "string" },
        "split_scores": { "type": "object" },
        "judge_status": { "type": "string" },
        "calibration": { "type": "object" },
        "notes": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
